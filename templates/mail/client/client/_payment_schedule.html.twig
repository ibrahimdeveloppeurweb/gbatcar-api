{% extends "shared/mail/layout.html.twig" %}

{% block body %}
 <table class="es-content" cellspacing="0" cellpadding="0" align="center">
        <tbody>
            <tr>
                <td class="esd-stripe" align="center">
                    <table class="es-content-body" width="765" cellspacing="0" cellpadding="0" bgcolor="#ffffff" align="center">
                        <tbody>
                            <tr>
                                <td class="esd-structure es-p20t es-p35r es-p35l" esd-custom-block-id="7685" align="left">
                                    <table width="100%" cellspacing="0" cellpadding="0">
                                        <tbody>
                                            <tr>
                                                <td class="esd-container-frame" width="530" valign="top" align="center">
                                                    <table width="100%" cellspacing="0" cellpadding="0">
                                                        <tbody>
                                                            <tr>
  							                                    {{ include('shared/mail/_logo.html.twig') }}
                                                            </tr>
                                                            <tr>
                                                                <td class="esd-block-text" align="center">
                                                                    <h2 style="font-size: 20px;">Bonjour {{ client.civilite ~ ' ' ~ client.lastName }}<br></h2>
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td class="esd-block-text es-p15t es-p10b" align="center">
                                                                    <p style="font-size: 16px; color: #777777;">
                                                                        Voici le calendrier de paiement détaillé relatif à votre contrat <strong>{{ contract.reference }}</strong>.
                                                                    </p>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td class="esd-structure es-p20t es-p40b es-p35r es-p35l" align="left">
                                    <table width="100%" cellspacing="0" cellpadding="0">
                                        <tbody>
                                            <tr>
                                                <td class="esd-container-frame" width="530" valign="top" align="center">
                                                    <table width="100%" cellspacing="0" cellpadding="0" style="border: 1px solid #eeeeee; border-collapse: collapse;">
                                                        <thead>
                                                            <tr bgcolor="#f8f9fa">
                                                                <th style="padding: 10px; border-bottom: 2px solid #dee2e6; text-align: left;">Date Prévue</th>
                                                                <th style="padding: 10px; border-bottom: 2px solid #dee2e6; text-align: right;">Montant (FCFA)</th>
                                                                <th style="padding: 10px; border-bottom: 2px solid #dee2e6; text-align: center;">Type</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            {% for schedule in schedules %}
                                                            <tr>
                                                                <td style="padding: 10px; border-bottom: 1px solid #eeeeee; font-size: 14px;">{{ schedule.expectedDate|date("d/m/Y") }}</td>
                                                                <td style="padding: 10px; border-bottom: 1px solid #eeeeee; font-size: 14px; text-align: right; font-weight: bold;">{{ schedule.amount|number_format(0, '.', ' ') }}</td>
                                                                <td style="padding: 10px; border-bottom: 1px solid #eeeeee; font-size: 14px; text-align: center;">{{ schedule.type }}</td>
                                                            </tr>
                                                            {% endfor %}
                                                        </tbody>
                                                    </table>
                                                    
                                                    <table width="100%" cellspacing="0" cellpadding="0" style="margin-top: 30px;">
                                                        <tbody>
                                                            <tr>
                                                                <td align="left">
                                                                    <p style="margin: 10px 0; font-size: 14px; color: #555555;">
                                                                        <span style="font-weight: bold;">Montant Total Contractuel : </span> {{ contract.totalAmount|number_format(0, '.', ' ') }} FCFA
                                                                    </p>
                                                                    <p style="margin: 10px 0; font-size: 14px; color: #555555;">
                                                                        <span style="font-weight: bold;">Périodicité : </span> 
                                                                        {% set freq = contract.paymentFrequency|lower %}
                                                                        {% if 'monthly' in freq or 'mensu' in freq %}Mensuelle
                                                                        {% elseif 'weekly' in freq or 'hebdo' in freq %}Hebdomadaire
                                                                        {% elseif 'daily' in freq or 'journ' in freq or 'quoti' in freq %}Journalière
                                                                        {% else %}{{ contract.paymentFrequency }}{% endif %}
                                                                    </p>
                                                                    {% if vehicle %}
                                                                    <p style="margin: 10px 0; font-size: 14px; color: #555555;">
                                                                        <span style="font-weight: bold;">Véhicule : </span> {{ vehicle.marque ~ ' ' ~ vehicle.modele ~ ' (' ~ vehicle.immatriculation ~ ')' }}
                                                                    </p>
                                                                    {% endif %}
                                                                    
                                                                    <hr style="border: 0; border-top: 1px solid #eeeeee; margin: 20px 0;">
                                                                    
                                                                    <p style="margin: 10px 0; font-size: 14px; font-weight: bold;">Informations importantes :</p>
                                                                    <ul style="font-size: 13px; color: #777777; padding-left: 20px;">
                                                                        <li>Veuillez respecter les dates d'échéance pour éviter des pénalités de retard.</li>
                                                                        <li>Vous pouvez suivre vos paiements en temps réel sur l'application mobile GBATCAR.</li>
                                                                        <li>En cas de difficulté de paiement, merci de contacter votre conseiller au plus tôt.</li>
                                                                    </ul>
                                                                    
                                                                    <p style="margin: 20px 0 10px 0; font-weight: bold">Merci de votre confiance.</p>
                                                                    <p style="margin: 0; font-weight: bold">L'équipe GBATCAR</p>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </td>
            </tr>
        </tbody>
    </table>
{% endblock %}

{% block content %}{% endblock %}
