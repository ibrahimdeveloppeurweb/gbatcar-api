{% extends "shared/mail/layout.html.twig" %}

{% block body %}
 <table class="es-content" cellspacing="0" cellpadding="0" align="center">
        <tbody>
            <tr>
                <td class="esd-stripe" align="center">
                    <table class="es-content-body" width="765" cellspacing="0" cellpadding="0" bgcolor="#ffffff" align="center">
                        <tbody>
                            <tr>
                                <td class="esd-structure es-p20t es-p35r es-p35l" esd-custom-block-id="7685" align="left">
                                    <table width="100%" cellspacing="0" cellpadding="0">
                                        <tbody>
                                            <tr>
                                                <td class="esd-container-frame" width="530" valign="top" align="center">
                                                    <table width="100%" cellspacing="0" cellpadding="0">
                                                        <tbody>
                                                            <tr>
							                                    {{ include('shared/mail/_logo.html.twig') }}
                                                            </tr>
                                                            <tr>
                                                                <td class="esd-block-text" align="center">
                                                                    <h2 style="font-size: 20px;">Confirmation de demande de souscription - GBATCAR<br></h2>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td class="esd-structure es-p20t es-p40b es-p35r es-p35l" esd-custom-block-id="7685" align="left">
                                    <table width="100%" cellspacing="0" cellpadding="0">
                                        <tbody>
                                            <tr>
                                                <td class="esd-container-frame" width="530" valign="top" align="center">
                                                    <table width="100%" cellspacing="0" cellpadding="0">
                                                        <tbody>
                                                            <tr>
                                                                <td class="esd-block-text es-p20t" align="center">
                                                                    <p style="font-size: 16px; color: #777777;">
                                                                        <p style="margin: 10px 0; padding: 3px; text-align: left; font-weight: bold">Bonjour {{ subscription.fullName }},</p>
                                                                        <p style="margin: 10px 0; padding: 3px; text-align: left;">Nous avons bien reçu votre demande de souscription pour un contrat de type <strong>{{ subscription.contractType }}</strong>.</p>
                                                                        <p style="margin: 10px 0; padding: 3px; text-align: left;">Notre équipe examine actuellement vos documents et votre dossier. Nous reviendrons vers vous dans les plus brefs délais pour vous informer de la suite de votre demande.</p>
                                                                        
                                                                        <div style="background-color: #f9f9f9; padding: 15px; margin: 20px 0; border-radius: 5px; text-align: left;">
                                                                            <p style="margin: 5px 0;"><strong>Récapitulatif de votre demande :</strong></p>
                                                                            <ul style="list-style-type: none; padding-left: 0;">
                                                                                <li>Type de client : {{ subscription.clientType }}</li>
                                                                                <li>Véhicule souhaité : {{ subscription.vehicleType }} (x{{ subscription.vehicleCount }})</li>
                                                                                <li>Mode de paiement : {{ subscription.paymentMethod }}</li>
                                                                            </ul>
                                                                        </div>

                                                                        <p style="margin: 10px 0; padding: 3px; text-align: left;">Si vous avez des questions entre-temps, n'hésitez pas à nous contacter.</p>
                                                                        
                                                                        <p style="margin: 10px 0; padding: 3px; text-align: left; font-weight: bold">Cordialement,</p>
                                                                        <p style="margin: 10px 0; padding: 3px; text-align: left; font-weight: bold">L'équipe GBATCAR</p>
                                                                    </p>
                                                                </td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </td>
            </tr>
        </tbody>
    </table>
{% endblock %}

{% block content %}{% endblock %}
